<section class="section newsletter">
  <div class="container newsletter__inner">
    <div>
      <h2 class="section-title">{{ section.settings.heading }}</h2>
      <p>{{ section.settings.text }}</p>
    </div>
    <div>
      {%- form 'customer', class: 'newsletter-form' -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <label class="visually-hidden" for="NewsletterEmail">Email</label>
        <input id="NewsletterEmail" type="email" name="contact[email]" value="{% if customer %}{{ customer.email }}{% endif %}" placeholder="Enter your email" required>
        <button class="button button--secondary" type="submit">{{ section.settings.button_label }}</button>
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stay updated on offers and new arrivals" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Use this section for deals, seasonal drops, and convenience-store promotions." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Join now" }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
