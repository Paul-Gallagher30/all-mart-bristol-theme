<section class="section">
  <div class="container">
    <h1 class="section-title">Your cart</h1>
    {%- if cart.item_count > 0 -%}
      <form action="{{ routes.cart_url }}" method="post">
        <div class="main-cart__layout">
          <div class="cart-items">
            {%- for item in cart.items -%}
              <article class="cart-item card">
                <div>
                  {%- if item.image != blank -%}
                    {{ item.image | image_url: width: 220 | image_tag: loading: 'lazy', widths: '110,220', sizes: '110px', alt: item.product.title | escape }}
                  {%- endif -%}
                </div>
                <div class="cart-item__details">
                  <h3><a href="{{ item.url }}">{{ item.product.title }}</a></h3>
                  <p>{{ item.final_line_price | money }}</p>
                  <label for="Updates_{{ item.index | plus: 1 }}">Quantity</label><br>
                  <input id="Updates_{{ item.index | plus: 1 }}" type="number" name="updates[]" value="{{ item.quantity }}" min="0">
                </div>
                <div>
                  <a class="button button--secondary" href="{{ item.url_to_remove }}">Remove</a>
                </div>
              </article>
            {%- endfor -%}
          </div>

          <aside class="cart-summary card">
            <h2>Summary</h2>
            <p>Subtotal: <strong>{{ cart.total_price | money }}</strong></p>
            <p class="card-footer-note">Taxes and shipping are calculated at checkout.</p>
            <div style="display:grid; gap:.75rem; margin-top:1rem;">
              <button class="button button--secondary" type="submit" name="update">Update cart</button>
              <button class="button" type="submit" name="checkout">Checkout</button>
            </div>
          </aside>
        </div>
      </form>
    {%- else -%}
      <div class="empty-state card">
        <h2>Your cart is empty</h2>
        <p>Start with one of your key collections to guide customers into the catalogue.</p>
        <a class="button" href="{{ routes.all_products_collection_url }}">Continue shopping</a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main cart",
  "settings": []
}
{% endschema %}
