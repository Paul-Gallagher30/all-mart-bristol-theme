<section class="section collection-banner">
  <div class="container">
    <div class="collection-banner__wrap card">
      <div class="collection-banner__content">
        <span class="badge">Collection</span>
        <h1 class="section-title">{{ collection.title }}</h1>
        <div class="section-subtitle rte">
          {%- if collection.description != blank -%}
            {{ collection.description }}
          {%- else -%}
            <p>{{ section.settings.fallback_text }}</p>
          {%- endif -%}
        </div>
        <div class="collection-banner__stats">
          <div class="collection-banner__stat card"><strong>{{ collection.products_count }}</strong><br>Products</div>
          <div class="collection-banner__stat card"><strong>{{ section.settings.stat_two_title }}</strong><br>{{ section.settings.stat_two_text }}</div>
          <div class="collection-banner__stat card"><strong>{{ section.settings.stat_three_title }}</strong><br>{{ section.settings.stat_three_text }}</div>
        </div>
      </div>
      <div>
        {%- if collection.featured_image != blank -%}
          {{ collection.featured_image | image_url: width: 1600 | image_tag: loading: 'eager', widths: '540,720,960,1200,1600', sizes: '(min-width: 990px) 50vw, 100vw', alt: collection.title | escape, style: 'width:100%;height:100%;object-fit:cover;' }}
        {%- elsif collection.products.first.featured_image != blank -%}
          {{ collection.products.first.featured_image | image_url: width: 1600 | image_tag: loading: 'eager', widths: '540,720,960,1200,1600', sizes: '(min-width: 990px) 50vw, 100vw', alt: collection.title | escape, style: 'width:100%;height:100%;object-fit:cover;' }}
        {%- else -%}
          {{ 'collection-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main collection banner",
  "settings": [
    { "type": "textarea", "id": "fallback_text", "label": "Fallback text", "default": "Use each collection page to reinforce what shoppers will find in that category and why it matters." },
    { "type": "text", "id": "stat_two_title", "label": "Second stat title", "default": "Curated" },
    { "type": "text", "id": "stat_two_text", "label": "Second stat text", "default": "Clear product grouping" },
    { "type": "text", "id": "stat_three_title", "label": "Third stat title", "default": "Designed" },
    { "type": "text", "id": "stat_three_text", "label": "Third stat text", "default": "For faster browsing" }
  ]
}
{% endschema %}
