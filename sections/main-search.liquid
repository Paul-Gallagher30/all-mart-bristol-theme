<section class="section main-search">
  <div class="container">
    <h1 class="section-title">Search</h1>
    <form class="search-form" action="{{ routes.search_url }}" method="get" role="search">
      <label class="visually-hidden" for="SearchInput">Search</label>
      <input id="SearchInput" type="search" name="q" value="{{ search.terms | escape }}" placeholder="Search products, collections, pages...">
      <button class="button" type="submit">Search</button>
    </form>

    {%- if search.performed -%}
      <p class="section-subtitle">{{ search.results_count }} result{% if search.results_count != 1 %}s{% endif %} for “{{ search.terms }}”.</p>
      <div class="product-grid search-grid">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- elsif item.object_type == 'collection' -%}
            <a href="{{ item.url }}">{% render 'collection-card', collection: item %}</a>
          {%- else -%}
            <article class="card" style="padding:1rem;">
              <h3><a href="{{ item.url }}">{{ item.title }}</a></h3>
              <p>{{ item.content | strip_html | truncate: 120 }}</p>
            </article>
          {%- endif -%}
        {%- else -%}
          <p>No results found.</p>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Main search",
  "settings": []
}
{% endschema %}
