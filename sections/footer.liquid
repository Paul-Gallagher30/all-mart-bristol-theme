<footer class="site-footer section">
  <div class="container">
    <div class="footer__grid">
      <div class="footer__brand">
        <h2>{{ shop.name }}</h2>
        <p>{{ section.settings.footer_text }}</p>
      </div>

      <div>
        <h3>{{ section.settings.menu_heading }}</h3>
        <nav class="footer__menu" aria-label="Footer">
          {%- for link in section.settings.menu.links -%}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {%- endfor -%}
        </nav>
      </div>

      <div>
        <h3>Store details</h3>
        <div class="footer__menu footer__meta">
          <span>{{ section.settings.location_text }}</span>
          <span>{{ section.settings.contact_text }}</span>
          <span>{{ section.settings.hours_text }}</span>
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <small>© {{ 'now' | date: '%Y' }} {{ shop.name }}. Built for Shopify.</small>
      <small>{{ powered_by_link }}</small>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "textarea", "id": "footer_text", "label": "Footer text", "default": "All Mart Bristol is designed as a clean, modern storefront for everyday essentials, home picks, pantry staples, and value-driven shopping." },
    { "type": "text", "id": "menu_heading", "label": "Menu heading", "default": "Quick links" },
    { "type": "link_list", "id": "menu", "label": "Footer menu", "default": "footer" },
    { "type": "text", "id": "location_text", "label": "Location text", "default": "Bristol, United Kingdom" },
    { "type": "text", "id": "contact_text", "label": "Contact text", "default": "Email, WhatsApp, or phone details can be added here" },
    { "type": "text", "id": "hours_text", "label": "Hours text", "default": "Open daily — update with your real timings" }
  ]
}
{% endschema %}
