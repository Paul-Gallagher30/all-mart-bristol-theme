<section class="section section--tight marketplace-hero">
  <div class="container marketplace-hero__grid">
    <div class="marketplace-hero__main card">
      <div class="marketplace-hero__content">
        <span class="badge">{{ section.settings.eyebrow }}</span>
        <h1 class="marketplace-hero__title">{{ section.settings.heading }}</h1>
        <p class="marketplace-hero__text">{{ section.settings.text }}</p>
        <div class="hero__actions">
          <a class="button" href="{{ section.settings.primary_link | default: '/collections/all' }}">{{ section.settings.primary_label }}</a>
          <a class="button button--secondary" href="{{ section.settings.secondary_link | default: '/collections' }}">{{ section.settings.secondary_label }}</a>
        </div>
        {%- if section.blocks.size > 0 -%}
          <div class="marketplace-hero__chips">
            {%- for block in section.blocks -%}
              <a href="{{ block.settings.link | default: '/collections' }}" class="marketplace-chip" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      <div class="marketplace-hero__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1600 | image_tag: widths: '500,800,1200,1600', sizes: '(min-width: 990px) 42vw, 100vw', alt: section.settings.heading | escape }}
        {%- else -%}
          {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
    </div>

    <div class="marketplace-hero__side">
      {%- for i in (1..3) -%}
        {%- liquid
          assign title_key = 'promo_title_' | append: i
          assign text_key = 'promo_text_' | append: i
          assign label_key = 'promo_label_' | append: i
          assign link_key = 'promo_link_' | append: i
        -%}
        <a class="promo-tile card" href="{{ section.settings[link_key] | default: '/collections' }}">
          <span class="promo-tile__eyebrow">Featured</span>
          <h3>{{ section.settings[title_key] }}</h3>
          <p>{{ section.settings[text_key] }}</p>
          <span class="promo-tile__cta">{{ section.settings[label_key] }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marketplace hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "All Mart Bristol" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by category, discover deals, and find everyday essentials fast." },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Built for a broad catalogue store with groceries, household products, snacks, personal care, gifts, and seasonal picks. Use the homepage to drive shoppers straight into departments instead of making them hunt for products." },
    { "type": "image_picker", "id": "image", "label": "Hero image" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop all products" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Browse categories" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "text", "id": "promo_title_1", "label": "Promo 1 title", "default": "Shop pantry staples" },
    { "type": "textarea", "id": "promo_text_1", "label": "Promo 1 text", "default": "Feature your highest-volume essentials or fast-moving daily-use products." },
    { "type": "text", "id": "promo_label_1", "label": "Promo 1 CTA label", "default": "View collection" },
    { "type": "url", "id": "promo_link_1", "label": "Promo 1 link" },
    { "type": "text", "id": "promo_title_2", "label": "Promo 2 title", "default": "Trending snacks & drinks" },
    { "type": "textarea", "id": "promo_text_2", "label": "Promo 2 text", "default": "Create a fast-converting category for impulse purchases and popular add-ons." },
    { "type": "text", "id": "promo_label_2", "label": "Promo 2 CTA label", "default": "Shop now" },
    { "type": "url", "id": "promo_link_2", "label": "Promo 2 link" },
    { "type": "text", "id": "promo_title_3", "label": "Promo 3 title", "default": "Home & personal care" },
    { "type": "textarea", "id": "promo_text_3", "label": "Promo 3 text", "default": "Use this tile for repeat-purchase categories that keep customers coming back." },
    { "type": "text", "id": "promo_label_3", "label": "Promo 3 CTA label", "default": "Explore" },
    { "type": "url", "id": "promo_link_3", "label": "Promo 3 link" }
  ],
  "blocks": [
    {
      "type": "chip",
      "name": "Quick chip",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Top category" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 10,
  "presets": [
    {
      "name": "Marketplace hero",
      "blocks": [
        { "type": "chip", "settings": { "label": "Groceries" } },
        { "type": "chip", "settings": { "label": "Snacks" } },
        { "type": "chip", "settings": { "label": "Drinks" } },
        { "type": "chip", "settings": { "label": "Home essentials" } },
        { "type": "chip", "settings": { "label": "Personal care" } }
      ]
    }
  ]
}
{% endschema %}
