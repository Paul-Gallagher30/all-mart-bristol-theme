<section class="section featured-collections">
  <div class="container">
    <h2 class="section-title">{{ section.settings.heading }}</h2>
    <p class="section-subtitle">{{ section.settings.subtext }}</p>

    <div class="featured-collections__grid">
      {%- for block in section.blocks -%}
        {%- assign featured_collection = collections[block.settings.collection] -%}
        {%- if featured_collection != blank -%}
          <a href="{{ featured_collection.url }}" {{ block.shopify_attributes }}>
            {% render 'collection-card', collection: featured_collection %}
          </a>
        {%- else -%}
          <article class="collection-card card" {{ block.shopify_attributes }}>
            <div class="collection-card__content">
              <h3>{{ block.settings.fallback_title }}</h3>
              <p>{{ block.settings.fallback_text }}</p>
              <span class="badge">Assign a collection</span>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured collections",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by collection" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Use this section to map your real Shopify collections from the admin. Swap the sample placeholders for the collection structure you finalized." }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "fallback_title", "label": "Fallback title", "default": "Groceries & pantry" },
        { "type": "textarea", "id": "fallback_text", "label": "Fallback text", "default": "Assign one of your real collections here from the theme editor." }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "Featured collections",
      "blocks": [
        { "type": "collection", "settings": { "fallback_title": "Groceries & pantry", "fallback_text": "Staples, cupboard picks, and everyday essentials." } },
        { "type": "collection", "settings": { "fallback_title": "Snacks & drinks", "fallback_text": "Impulse buys, treats, and bestsellers for quick orders." } },
        { "type": "collection", "settings": { "fallback_title": "Home essentials", "fallback_text": "Practical daily-use products for the home." } },
        { "type": "collection", "settings": { "fallback_title": "Health & beauty", "fallback_text": "Personal care and everyday wellbeing picks." } }
      ]
    }
  ]
}
{% endschema %}
