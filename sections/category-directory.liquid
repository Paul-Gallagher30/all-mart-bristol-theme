<section class="section category-directory">
  <div class="container">
    <div class="section-heading-row">
      <div>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <p class="section-subtitle">{{ section.settings.subtext }}</p>
      </div>
    </div>

    {%- if section.settings.menu != blank and section.settings.menu.links.size > 0 -%}
      <div class="category-directory__grid">
        {%- for link in section.settings.menu.links -%}
          <div class="category-directory__column card">
            <a class="category-directory__title" href="{{ link.url }}">{{ link.title }}</a>
            {%- if link.links != blank -%}
              <ul class="category-directory__list" role="list">
                {%- for child_link in link.links -%}
                  <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- else -%}
              <p class="card-footer-note">Add child links inside your Shopify menu to turn this into a proper department directory.</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="card empty-state-card">
        <h3>No departments menu assigned yet</h3>
        <p>Assign a nested Shopify menu to this section and it will automatically output your main categories with subcategories below them.</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Category directory",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Department directory" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "This section is ideal for an Amazon-style category page. It reads a nested Shopify menu and turns it into a browsable directory." },
    { "type": "link_list", "id": "menu", "label": "Directory menu" }
  ],
  "presets": [
    { "name": "Category directory" }
  ]
}
{% endschema %}
