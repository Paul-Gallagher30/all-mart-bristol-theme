<section class="section section--tight trust-bar">
  <div class="container">
    <div class="trust-bar__grid">
      {%- for block in section.blocks -%}
        <div class="trust-item card" {{ block.shopify_attributes }}>
          <div class="badge">{{ block.settings.icon }}</div>
          <h3>{{ block.settings.heading }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust bar",
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        { "type": "text", "id": "icon", "label": "Icon text", "default": "✓" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Fast browsing" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Simple navigation and clear collection access from the first screen." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "Trust bar",
      "blocks": [
        { "type": "item", "settings": { "icon": "⚡", "heading": "Fast storefront", "text": "Light, HTML-first layout inspired by high-speed theme principles." } },
        { "type": "item", "settings": { "icon": "🛍", "heading": "Collection-led", "text": "Built to spotlight your strongest categories and help shoppers browse quickly." } },
        { "type": "item", "settings": { "icon": "📱", "heading": "Mobile ready", "text": "Responsive layout with strong CTA placement for phone-first customers." } },
        { "type": "item", "settings": { "icon": "🧭", "heading": "Easy to manage", "text": "Sections and blocks are customizable from the latest Shopify editor." } }
      ]
    }
  ]
}
{% endschema %}
