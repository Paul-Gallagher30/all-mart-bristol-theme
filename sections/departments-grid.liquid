<section class="section departments-grid-section">
  <div class="container">
    <div class="section-heading-row">
      <div>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <p class="section-subtitle">{{ section.settings.subtext }}</p>
      </div>
      {%- if section.settings.link_label != blank -%}
        <a class="button button--secondary" href="{{ section.settings.link_url | default: '/collections' }}">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>

    <div class="departments-grid">
      {%- for block in section.blocks -%}
        {%- assign category_collection = collections[block.settings.collection] -%}
        <a class="department-card card" href="{% if category_collection != blank %}{{ category_collection.url }}{% elsif block.settings.link != blank %}{{ block.settings.link }}{% else %}#{% endif %}" {{ block.shopify_attributes }}>
          <div class="department-card__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: widths: '300,450,700,900', sizes: '(min-width: 990px) 16vw, 48vw', alt: block.settings.title | escape }}
            {%- elsif category_collection != blank and category_collection.featured_image != blank -%}
              {{ category_collection.featured_image | image_url: width: 900 | image_tag: widths: '300,450,700,900', sizes: '(min-width: 990px) 16vw, 48vw', alt: category_collection.title | escape }}
            {%- elsif category_collection != blank and category_collection.products.first.featured_image != blank -%}
              {{ category_collection.products.first.featured_image | image_url: width: 900 | image_tag: widths: '300,450,700,900', sizes: '(min-width: 990px) 16vw, 48vw', alt: category_collection.title | escape }}
            {%- else -%}
              {{ 'collection-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
            {%- endif -%}
          </div>
          <div class="department-card__content">
            <h3>{% if category_collection != blank %}{{ category_collection.title }}{% else %}{{ block.settings.title }}{% endif %}</h3>
            <p>{% if block.settings.text != blank %}{{ block.settings.text }}{% elsif category_collection != blank and category_collection.description != blank %}{{ category_collection.description | strip_html | truncate: 90 }}{% else %}Build a department that groups related products for faster shopping.{% endif %}</p>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Departments grid",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop by department" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "This is the most important homepage section for a marketplace-style store. Map each card to one of your real Shopify collections." },
    { "type": "text", "id": "link_label", "label": "Top-right button label", "default": "All categories" },
    { "type": "url", "id": "link_url", "label": "Top-right button link" }
  ],
  "blocks": [
    {
      "type": "department",
      "name": "Department",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Custom image" },
        { "type": "text", "id": "title", "label": "Fallback title", "default": "Department title" },
        { "type": "textarea", "id": "text", "label": "Custom text" },
        { "type": "url", "id": "link", "label": "Fallback link" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Departments grid",
      "blocks": [
        { "type": "department", "settings": { "title": "Groceries & pantry" } },
        { "type": "department", "settings": { "title": "Snacks & drinks" } },
        { "type": "department", "settings": { "title": "Home essentials" } },
        { "type": "department", "settings": { "title": "Health & beauty" } },
        { "type": "department", "settings": { "title": "Seasonal offers" } },
        { "type": "department", "settings": { "title": "Gifts & bundles" } }
      ]
    }
  ]
}
{% endschema %}
