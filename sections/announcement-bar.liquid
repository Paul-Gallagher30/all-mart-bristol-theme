{%- if section.settings.show_announcement -%}
  <div class="announcement-bar">
    <div class="container announcement-bar__inner">
      <span>{{ section.settings.text }}</span>
      {%- if section.settings.link != blank and section.settings.link_text != blank -%}
        <a href="{{ section.settings.link }}"><strong>{{ section.settings.link_text }}</strong></a>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show_announcement", "label": "Show announcement", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "Fast delivery, local favourites, and everyday essentials from All Mart Bristol." },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "Browse collections" },
    { "type": "url", "id": "link", "label": "Link" }
  ]
}
{% endschema %}
