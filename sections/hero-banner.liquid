<section class="hero section">
  <div class="container hero__inner">
    <div class="hero__content">
      {%- if section.settings.eyebrow != blank -%}
        <div class="hero__eyebrow badge">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h1 class="hero__title">{{ section.settings.heading }}</h1>
      <div class="hero__text rte">{{ section.settings.text }}</div>
      <div class="hero__actions">
        {%- if section.settings.primary_link != blank and section.settings.primary_label != blank -%}
          <a class="button" href="{{ section.settings.primary_link }}">{{ section.settings.primary_label }}</a>
        {%- endif -%}
        {%- if section.settings.secondary_link != blank and section.settings.secondary_label != blank -%}
          <a class="button button--secondary" href="{{ section.settings.secondary_link }}">{{ section.settings.secondary_label }}</a>
        {%- endif -%}
      </div>
      <div class="hero__highlights">
        {%- for block in section.blocks -%}
          <span class="badge" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
        {%- endfor -%}
      </div>
    </div>

    <div class="hero__media-wrap">
      <div class="hero__media card">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager', widths: '540, 720, 960, 1200, 1400', sizes: '(min-width: 990px) 50vw, 100vw', alt: section.settings.heading | escape }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="hero__floating-card card">
        <strong>{{ section.settings.floating_title }}</strong>
        <p>{{ section.settings.floating_text }}</p>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "All Mart Bristol" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "A cleaner, faster store for everyday shopping." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Build trust quickly with a modern homepage that highlights your collections, bestsellers, value messaging, and local convenience.</p>" },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Shop all collections" },
    { "type": "url", "id": "primary_link", "label": "Primary button link" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "View bestsellers" },
    { "type": "url", "id": "secondary_link", "label": "Secondary button link" },
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "floating_title", "label": "Floating card title", "default": "Designed for conversion" },
    { "type": "textarea", "id": "floating_text", "label": "Floating card text", "default": "Large call-to-actions, clean collection cards, and product-first layouts help shoppers reach checkout faster." }
  ],
  "blocks": [
    {
      "type": "highlight",
      "name": "Highlight",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Fast delivery" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "Hero banner",
      "blocks": [
        { "type": "highlight", "settings": { "text": "Local convenience" } },
        { "type": "highlight", "settings": { "text": "Bestseller ready" } },
        { "type": "highlight", "settings": { "text": "Mobile-first" } }
      ]
    }
  ]
}
{% endschema %}
