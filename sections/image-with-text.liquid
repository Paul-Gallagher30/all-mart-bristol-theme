<section class="section">
  <div class="container">
    <div class="image-with-text__wrap card">
      <div class="image-with-text__media">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '540,720,960,1200,1400', sizes: '(min-width: 990px) 50vw, 100vw', alt: section.settings.heading | escape }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      <div class="image-with-text__content">
        <span class="badge">{{ section.settings.badge }}</span>
        <h2 class="section-title">{{ section.settings.heading }}</h2>
        <div class="section-subtitle rte">{{ section.settings.text }}</div>
        {%- if section.settings.link != blank and section.settings.link_label != blank -%}
          <a class="button" href="{{ section.settings.link }}">{{ section.settings.link_label }}</a>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Image with text",
  "settings": [
    { "type": "text", "id": "badge", "label": "Badge", "default": "Why this theme fits" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Built for a broad catalogue without looking cluttered." },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>All Mart Bristol needs a theme that can handle multiple collections while still feeling clean and curated. This layout uses hierarchy, spacing, and strong collection tiles to make a wide product mix feel easier to browse.</p>" },
    { "type": "text", "id": "link_label", "label": "Link label", "default": "Explore all products" },
    { "type": "url", "id": "link", "label": "Link" },
    { "type": "image_picker", "id": "image", "label": "Image" }
  ],
  "presets": [
    { "name": "Image with text" }
  ]
}
{% endschema %}
