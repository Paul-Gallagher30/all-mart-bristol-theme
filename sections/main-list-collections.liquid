<section class="section main-list-collections">
  <div class="container">
    <div class="section-heading-row">
      <div>
        <h1 class="section-title">{{ section.settings.heading }}</h1>
        <p class="section-subtitle">{{ section.settings.subtext }}</p>
      </div>
    </div>

    <div class="list-collections__grid">
      {%- if section.settings.collection_menu != blank and section.settings.collection_menu.links.size > 0 -%}
        {%- for link in section.settings.collection_menu.links -%}
          {%- if link.type == 'collection_link' and link.object != blank -%}
            {% render 'collection-card', collection: link.object %}
          {%- elsif link.links != blank -%}
            {%- for child_link in link.links -%}
              {%- if child_link.type == 'collection_link' and child_link.object != blank -%}
                {% render 'collection-card', collection: child_link.object %}
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      {%- else -%}
        {%- for collection in collections -%}
          {% render 'collection-card', collection: collection %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main list collections",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse all categories" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "Use an ordered Shopify menu here if you want your categories displayed in a specific order instead of alphabetical order." },
    { "type": "link_list", "id": "collection_menu", "label": "Ordered collection menu" }
  ]
}
{% endschema %}
