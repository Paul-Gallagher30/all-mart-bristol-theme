<section class="section main-list-collections">
  <div class="container">
    <h1 class="section-title">{{ section.settings.heading }}</h1>
    <p class="section-subtitle">{{ section.settings.subtext }}</p>
    <div class="list-collections__grid">
      {%- for collection in collections -%}
        {% render 'collection-card', collection: collection %}
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Main list collections",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Browse all collections" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "This page works especially well for stores with a broad catalogue. It gives each collection space without making the homepage too crowded." }
  ]
}
{% endschema %}
